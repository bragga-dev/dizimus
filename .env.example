# ─── Django ───────────────────────────────────────────────
SECRET_KEY=troque-por-uma-chave-secreta-forte
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Banco de dados ───────────────────────────────────────
POSTGRES_DB=dizimus
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
DATABASE_URL=postgres://postgres:123456@db:5432/dizimus

# ─── Redis / Celery ───────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ─── MinIO (S3-compatible) ────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# Credenciais usadas pelo Django (podem ser iguais ao root em dev)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123

# Endpoint interno (entre containers) e externo (navegador)
AWS_S3_ENDPOINT_URL=http://minio:9000
MINIO_EXTERNAL_URL=http://localhost:9000

# Buckets
MINIO_BUCKET_MEDIA=dizimus-media
MINIO_BUCKET_STATIC=dizimus-static

AWS_STORAGE_BUCKET_NAME=dizimus-media
AWS_S3_REGION_NAME=us-east-1
AWS_S3_FILE_OVERWRITE=False
AWS_DEFAULT_ACL=None

# Asaas
ASAAS_API_KEY=xxxxxxxx
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
